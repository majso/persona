{
  "$schema": "https://deno.land/x/denon@2.5.0/schema.json",
  "scripts": {
    "start": {
      "cmd": "deno run ./server/app.ts",
      "desc": "Run server file",
      "env": {
        "PORT": "5000"
      },
      "allow": [
        "run", 
        "read",
        "write",
        "env",
        "net" 
      ]
    }
  }
}